# ─── Google ──────────────────────────────────────────────────────────────────
# Service Account JSON (cole o conteúdo do arquivo .json em uma única linha)
# NUNCA commite chaves reais — use só na Vercel / .env.local
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ID do Google Calendar (encontra em: Calendar Settings > Integrate calendar)
GOOGLE_CALENDAR_ID=seu-email@gmail.com
# E-mail do studio que deve receber notificações do Google Calendar
STUDIO_NOTIFICATION_EMAIL=studio@seudominio.com

# ID da Google Spreadsheet (está na URL da planilha)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# URL pública do app (usada em links e callbacks)
NEXT_PUBLIC_APP_URL=https://studio-booking-nu.vercel.app

# ─── PagBank (PIX + Cartão) ───────────────────────────────────────────────────
# Token de segurança da API PagBank
PAGBANK_TOKEN=seu_token_pagbank
# E-mail da conta PagBank
PAGBANK_EMAIL=seu@email.com
# sandbox | production
PAGBANK_ENV=production
# Chave pública tipo "card" (POST /public-keys com {"type":"card"} — ver README)
PAGBANK_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
# Webhook PagBank deve apontar para:
# https://studio-booking-nu.vercel.app/api/webhook/pagbank

# ─── Email (Resend) — OPCIONAL ────────────────────────────────────────────────
# Sem RESEND_API_KEY + EMAIL_FROM, o app não envia e-mail; o cliente usa o
# comprovante na tela do checkout (copiar / imprimir / PDF).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=Studio II <reservas@seudominio.com>

# ─── Booking Config ──────────────────────────────────────────────────────────
# Token para rodar setup inicial da planilha (GET /api/setup?token=...)
SETUP_TOKEN=troque-por-um-token-seguro
# Minutos para expirar a pré-reserva
HOLD_TIMEOUT_MINUTES=15
# Valor mostrado no frontend (deve bater com BASE_PRICE_CENTS)
NEXT_PUBLIC_BASE_PRICE_CENTS=20000
# Timeout mostrado no frontend (deve bater com HOLD_TIMEOUT_MINUTES)
NEXT_PUBLIC_HOLD_TIMEOUT_MINUTES=15
# Preço base da sessão em centavos
BASE_PRICE_CENTS=20000
# Adicional maquiador em centavos
ADDON_MAKEUP_CENTS=16000
# Adicional figurinista em centavos
ADDON_STYLIST_CENTS=30000
